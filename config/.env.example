# CrabRAG environment template.
# Copy to config/.env. The install scripts do this automatically and never overwrite an existing file.
# Do not put real API keys in version control.

# Project root. run.ps1/run.sh set this automatically; keep this commented unless you start services manually.
# CRABRAG_ROOT=/absolute/path/to/CrabRAG

# Python API endpoint used by the Bun gateway. run.ps1/run.sh set this automatically.
# RAG_BASE_URL=http://127.0.0.1:8001

# Web gateway port used by server/gateway.js. Set it in your shell before running run.ps1/run.sh if needed.
# PORT=3003

# Optional knowledge-base source directories. Use ; to separate multiple directories.
# Windows example:
# CRABRAG_DOCS_DIR=F:\trae\CrabRAG\docs;D:\shared\kb-docs
# Linux example:
# CRABRAG_DOCS_DIR=/opt/crabrag/docs;/mnt/shared/kb-docs
# Legacy alias still supported: ELCQA_DOCS_DIR

# Chat LLM endpoint, key, and model name are configured from the Settings page.
# API_BASE_URL / API_KEY / MODEL_NAME in config/.env are no longer read for chat.

# Optional separate local retrieval endpoint for embedding/rerank.
# EMBEDDING_PROVIDER=local_onnx
# EMBEDDING_BASE_URL=http://127.0.0.1:9997/v1
# EMBEDDING_API_KEY=
# EMBEDDING_MODEL=BAAI/bge-m3

# Optional separate API rerank endpoint.
# RERANK_BASE_URL=http://127.0.0.1:9997/v1
# RERANK_API_KEY=
